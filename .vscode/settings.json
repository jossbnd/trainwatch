{
  "[go]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "golang.go",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always"
    }
  },
  "go.useLanguageServer": true,
  "gopls": {
    "formatting.gofumpt": true,
    "formatting.local": "github.com/jossbnd/trainwatch"
  },
  "[go.mod]": {
    "editor.formatOnSave": true
  },
  "evenBetterToml.schema.associations": {
    ".air.toml": "https://raw.githubusercontent.com/air-verse/air/master/air_example.toml"
  },
  "monkeyC.jungleFiles": "garmin/monkey.jungle",
  "monkeyC.developerKeyPath": "garmin/developer_key",
  "monkeyC.typeCheckLevel": "Strict",
  "monkeyC.optimizationLevel": "Fast"
}
